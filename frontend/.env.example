# Frontend environment variables
# Copy to .env.local for local development overrides.

# Backend API URL (leave empty to use Vite's same-origin proxy in dev).
# Set to your Cloudflare Workers URL for production / Pages deployments:
#   VITE_API_URL=https://zwillingstag-api.<your-account>.workers.dev
VITE_API_URL=

# Alternatively, set the WebSocket URL directly:
# VITE_WS_URL=wss://zwillingstag-api.<your-account>.workers.dev/ws
VITE_WS_URL=
