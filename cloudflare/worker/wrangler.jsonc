{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "zwillingstag-api",
	"main": "src/worker.py",
	"compatibility_date": "2025-11-02",
	"compatibility_flags": [
		"python_workers",
		"python_dedicated_snapshot"
	],

	"kv_namespaces": [
		{
			"binding": "KV_CACHE",
			"id": "REPLACE_WITH_YOUR_KV_NAMESPACE_ID"
		}
	],

	"vars": {
		"OPENAI_MODEL": "gpt-4o-mini"
	},

	"observability": {
		"enabled": true
	}
}
